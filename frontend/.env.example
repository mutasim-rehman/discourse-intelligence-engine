# Local FastAPI backend (used when VITE_GRADIO_SPACE is not set)
VITE_API_BASE_URL=http://localhost:8000

# Hugging Face Gradio Space (when set, frontend uses this instead of local API)
# Example: VITE_GRADIO_SPACE=username/space-name
# VITE_GRADIO_SPACE=

# Optional: Hugging Face token for private Spaces
# VITE_HF_TOKEN=
